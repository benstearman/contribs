# .env file

# --- Database Credentials (for PostgreSQL) ---
POSTGRES_DB=contribs_db
POSTGRES_USER=contribs_user
POSTGRES_PASSWORD=contribs

# --- Django Settings ---
# Note: For production, SECRET_KEY should be long and truly random.
DJANGO_SECRET_KEY=yoursecretkeyhere_changeme!
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,contribs.app,www.contribs.app

# --- Other Environment Variables ---
DB_HOST=db
DB_PORT=5432
WEB_PORT=8000
